generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Live-Editable Site Content ────────────────────────────
model SiteContent {
  key       String   @id           // e.g. "hero_title", "hero_bg"
  value     String   @db.Text
  type      String   @default("TEXT") // TEXT or IMAGE
  label     String?                // Human-readable label for admin UI
  updatedAt DateTime @updatedAt
}

// User & Role System
enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   // Hashed password for NextAuth Credentials
  role      Role     @default(USER)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings   Booking[]
  complaints Complaint[]
}

// Room Management
enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model Room {
  id              String     @id @default(cuid())
  roomNumber      Int        @unique
  pricePerYear    Int
  hasAC           Boolean    @default(true)
  hasEnsuiteBath  Boolean    @default(true)
  sizeDescription String
  type            String     // "VVIP", "VIP", "Reguler AC", "Reguler Non-AC", "Ekonomis"
  status          RoomStatus @default(AVAILABLE)
  
  bookings        Booking[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// Booking Lifecycle
enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  roomId        String
  durationYears Int           @default(1)
  status        BookingStatus @default(PENDING)
  startDate     DateTime
  
  user          User          @relation(fields: [userId], references: [id])
  room          Room          @relation(fields: [roomId], references: [id])
  payments      Payment[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Billing / Payment
enum PaymentStatus {
  UNPAID
  PAID
  OVERDUE
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String
  amount      Int
  status      PaymentStatus @default(UNPAID)
  dueDate     DateTime
  paidAt      DateTime?
  receiptUrl  String?

  booking     Booking       @relation(fields: [bookingId], references: [id])
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Ticketing / Complaints
enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Complaint {
  id          String          @id @default(cuid())
  userId      String
  title       String
  description String
  status      ComplaintStatus @default(OPEN)
  imageUrl    String?

  user        User            @relation(fields: [userId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
